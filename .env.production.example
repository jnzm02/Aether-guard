# ─────────────────────────────────────────────────────────────────────────────
# Aether-Guard Production Environment Configuration
#
# Copy this file to .env on your production server and fill in the values
# ─────────────────────────────────────────────────────────────────────────────

# ── Claude AI Configuration ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# ── Agent Configuration ───────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.75        # Minimum confidence to execute actions (0.0-1.0)
DRY_RUN=false                    # Set true to disable actual remediation actions
POLL_INTERVAL=10                 # Seconds between listener polls

# ── Docker Registry (for CD pipeline) ─────────────────────────────────────────
DOCKER_REGISTRY=registry.digitalocean.com/your-registry
DOCKER_REGISTRY_USERNAME=your-username
DOCKER_REGISTRY_PASSWORD=dop_v1_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
IMAGE_TAG=latest                 # Will be overridden by CD pipeline

# ── Listener Configuration ────────────────────────────────────────────────────
PROMETHEUS_URL=http://prometheus:9090
TARGET_CONTAINER=target-service
MAX_QUEUE_SIZE=500

# ── Optional: Logging ─────────────────────────────────────────────────────────
# LOG_LEVEL=INFO                 # DEBUG, INFO, WARNING, ERROR

# ── Optional: Custom Paths ────────────────────────────────────────────────────
# ANALYSIS_LOG_PATH=/app/data/analyses.jsonl
# POSTMORTEM_DIR=/app/data/postmortems
